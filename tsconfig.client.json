{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": "js",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["js/**/*"],
  "exclude": ["node_modules"]
}
